# Maintainer: Dalton Alexandre <dalexandre@milcgroup.info>
pkgname=unifi-cli
pkgver=1.1.0
pkgrel=1
pkgdesc="UniFi Controller CLI tool for local network management"
arch=('x86_64' 'aarch64')
url="https://github.com/dl-alexandre/Local-UniFi-CLI"
license=('MIT')
depends=()
makedepends=('go')
source=("$pkgname-$pkgver.tar.gz::https://github.com/dl-alexandre/Local-UniFi-CLI/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$pkgname-$pkgver"
  export CGO_CPPFLAGS="${CPPFLAGS}"
  export CGO_CFLAGS="${CFLAGS}"
  export CGO_CXXFLAGS="${CXXFLAGS}"
  export CGO_LDFLAGS="${LDFLAGS}"
  export GOFLAGS="-buildmode=pie -trimpath -ldflags=-linkmode=external -mod=readonly -modcacherw"
  go build -o unifi ./cmd/unifi
}

package() {
  cd "$pkgname-$pkgver"
  install -Dm755 unifi "$pkgdir/usr/bin/unifi"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
